<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ImageViewer.Presentation.ViewModels"
        xmlns:loc="using:ImageViewer.Presentation.MarkupExtensions"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="ImageViewer.Presentation.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{loc:Loc AppTitle}"
        Width="1000" Height="700"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        Background="Transparent"
        CornerRadius="16"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Window.Styles>
        <Style Selector="Border.title-bar">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Height" Value="40" />
        </Style>
        <Style Selector="Button.traffic-light">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style Selector="Button.close-btn">
            <Setter Property="Background" Value="#FF5F57" />
        </Style>
        <Style Selector="Button.minimize-btn">
            <Setter Property="Background" Value="#FFBD2E" />
        </Style>
        <Style Selector="Button.maximize-btn">
            <Setter Property="Background" Value="#28C840" />
        </Style>
        <Style Selector="Button.traffic-light:pointerover /template/ContentPresenter">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Opacity" Value="0.8" />
        </Style>
        <Style Selector="Button.tool-btn">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.tool-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAltListLowBrush}" />
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainViewModel>
            <x:Arguments>
                <x:Null />
                <x:Null />
                <x:Null />
            </x:Arguments>
        </vm:MainViewModel>
    </Design.DataContext>

    <Border BorderBrush="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
        <DockPanel LastChildFill="True">

            <!-- 自定义标题栏 -->
            <Border DockPanel.Dock="Top"
                    Classes="title-bar"
                    PointerPressed="OnTitleBarPointerPressed">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <!-- 左侧：macOS 交通灯按钮 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Classes="traffic-light close-btn" Click="OnCloseClick" ToolTip.Tip="{loc:Loc Close}" />
                        <Button Classes="traffic-light minimize-btn" Click="OnMinimizeClick" ToolTip.Tip="{loc:Loc Minimize}" />
                        <Button Classes="traffic-light maximize-btn" Click="OnMaximizeClick" ToolTip.Tip="{loc:Loc Maximize}" />
                    </StackPanel>

                    <!-- 右侧工具按钮 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Classes="tool-btn" Content="📁" Click="OnOpenFileClick" ToolTip.Tip="{loc:Loc OpenImage}" />
                        <Button Classes="tool-btn" Content="📂" Click="OnOpenFolderClick" ToolTip.Tip="{loc:Loc OpenFolder}" />
                        <Button Classes="tool-btn" Content="◐" Command="{Binding ToggleThemeCommand}"
                                ToolTip.Tip="{loc:Loc ToggleTheme}" />
                        <Button Classes="tool-btn" Content="⛶" Command="{Binding ToggleFullScreenCommand}"
                                ToolTip.Tip="{loc:Loc FullScreen}" />
                        <Button Classes="tool-btn" Content="↻" Command="{Binding RotateClockwiseCommand}"
                                ToolTip.Tip="{loc:Loc RotateClockwise}" />
                        <Button Classes="tool-btn" Content="↺" Command="{Binding RotateCounterClockwiseCommand}"
                                ToolTip.Tip="{loc:Loc RotateCounterClockwise}" />
                        <Button Classes="tool-btn" Content="+" Command="{Binding ZoomInCommand}"
                                ToolTip.Tip="{loc:Loc ZoomIn}" />
                        <Button Classes="tool-btn" Content="−" Command="{Binding ZoomOutCommand}"
                                ToolTip.Tip="{loc:Loc ZoomOut}" />
                        <Button Classes="tool-btn" Content="🗗" Command="{Binding ResetTransformCommand}"
                                ToolTip.Tip="{loc:Loc Reset}" />
                        <Button Classes="tool-btn" Content="◀" Command="{Binding PreviousCommand}"
                                IsEnabled="{Binding CanGoPrevious}" ToolTip.Tip="{loc:Loc Previous}" />
                        <Button Classes="tool-btn" Content="▶" Command="{Binding NextCommand}"
                                IsEnabled="{Binding CanGoNext}" ToolTip.Tip="{loc:Loc Next}" />
                        <Button Classes="tool-btn" Content="⚙" ToolTip.Tip="{loc:Loc Settings}">
                            <Button.Flyout>
                                <Flyout Placement="Bottom">
                                    <Border Padding="12" Width="220">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="{loc:Loc Language}" FontWeight="Medium" />
                                            <ComboBox ItemsSource="{Binding LanguageOptions}"
                                                      SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                                                      HorizontalAlignment="Stretch">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate DataType="vm:LanguageOption">
                                                        <TextBlock Text="{Binding DisplayName}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                    </Border>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border DockPanel.Dock="Bottom"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    Padding="12,4">
                <TextBlock Text="{Binding StatusMessage}" />
            </Border>

            <Panel Background="#1E1E1E">
                <ScrollViewer x:Name="ImageScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding HasImage}">
                    <LayoutTransformControl HorizontalAlignment="Center" VerticalAlignment="Center">
                        <LayoutTransformControl.LayoutTransform>
                            <TransformGroup>
                                <RotateTransform Angle="{Binding Rotation}" />
                                <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}" />
                            </TransformGroup>
                        </LayoutTransformControl.LayoutTransform>
                        <Image x:Name="ImageView"
                               Source="{Binding CurrentImage}"
                               Stretch="Uniform"
                               StretchDirection="DownOnly" />
                    </LayoutTransformControl>
                </ScrollViewer>

                <TextBlock Text="{loc:Loc OpenImagePrompt}"
                           Foreground="#888"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsVisible="{Binding !HasImage}" />
            </Panel>
        </DockPanel>
    </Border>
</Window>
