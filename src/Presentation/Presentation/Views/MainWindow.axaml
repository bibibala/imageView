<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ImageViewer.Presentation.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="ImageViewer.Presentation.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Image"
        Width="1000" Height="700"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        Background="Transparent"
        CornerRadius="16"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Window.Styles>
        <Style Selector="Border.title-bar">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Height" Value="40" />
        </Style>
        <Style Selector="Button.traffic-light">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style Selector="Button.close-btn">
            <Setter Property="Background" Value="#FF5F57" />
        </Style>
        <Style Selector="Button.minimize-btn">
            <Setter Property="Background" Value="#FFBD2E" />
        </Style>
        <Style Selector="Button.maximize-btn">
            <Setter Property="Background" Value="#28C840" />
        </Style>
        <Style Selector="Button.traffic-light:pointerover /template/ContentPresenter">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Opacity" Value="0.8" />
        </Style>
        <Style Selector="Button.tool-btn">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.tool-btn:pointerover /template/ContentPresenter">
            <Setter Property="Background" Value="#20FFFFFF" />
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainViewModel>
            <x:Arguments>
                <x:Null />
                <x:Null />
            </x:Arguments>
        </vm:MainViewModel>
    </Design.DataContext>

    <Border BorderBrush="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
        <DockPanel LastChildFill="True">

            <!-- 自定义标题栏 -->
            <Border DockPanel.Dock="Top"
                    Classes="title-bar"
                    PointerPressed="OnTitleBarPointerPressed">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <!-- 左侧：macOS 交通灯按钮 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Classes="traffic-light close-btn" Click="OnCloseClick" ToolTip.Tip="关闭" />
                        <Button Classes="traffic-light minimize-btn" Click="OnMinimizeClick" ToolTip.Tip="最小化" />
                        <Button Classes="traffic-light maximize-btn" Click="OnMaximizeClick" ToolTip.Tip="最大化" />
                    </StackPanel>

                    <!-- 右侧工具按钮 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Classes="tool-btn" Content="📁" Click="OnOpenFileClick" ToolTip.Tip="打开图片" />
                        <Button Classes="tool-btn" Content="📂" Click="OnOpenFolderClick" ToolTip.Tip="打开文件夹" />
                        <Button Classes="tool-btn" Content="◐" Command="{Binding ToggleThemeCommand}"
                                ToolTip.Tip="切换主题" />
                        <Button Classes="tool-btn" Content="⛶" Command="{Binding ToggleFullScreenCommand}"
                                ToolTip.Tip="全屏" />
                        <Button Classes="tool-btn" Content="↻" Command="{Binding RotateClockwiseCommand}"
                                ToolTip.Tip="右旋90°" />
                        <Button Classes="tool-btn" Content="↺" Command="{Binding RotateCounterClockwiseCommand}"
                                ToolTip.Tip="左旋90°" />
                        <Button Classes="tool-btn" Content="+" Command="{Binding ZoomInCommand}"
                                ToolTip.Tip="放大" />
                        <Button Classes="tool-btn" Content="−" Command="{Binding ZoomOutCommand}"
                                ToolTip.Tip="缩小" />
                        <Button Classes="tool-btn" Content="1" Command="{Binding ResetTransformCommand}"
                                ToolTip.Tip="重置" />
                        <Button Classes="tool-btn" Content="◀" Command="{Binding PreviousCommand}"
                                IsEnabled="{Binding CanGoPrevious}" ToolTip.Tip="上一张" />
                        <Button Classes="tool-btn" Content="▶" Command="{Binding NextCommand}"
                                IsEnabled="{Binding CanGoNext}" ToolTip.Tip="下一张" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border DockPanel.Dock="Bottom"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    Padding="12,4">
                <TextBlock Text="{Binding StatusMessage}" />
            </Border>

            <Panel Background="#1E1E1E">
                <ScrollViewer x:Name="ImageScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding HasImage}">
                    <LayoutTransformControl HorizontalAlignment="Center" VerticalAlignment="Center">
                        <LayoutTransformControl.LayoutTransform>
                            <TransformGroup>
                                <RotateTransform Angle="{Binding Rotation}" />
                                <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}" />
                            </TransformGroup>
                        </LayoutTransformControl.LayoutTransform>
                        <Image x:Name="ImageView"
                               Source="{Binding CurrentImage}"
                               Stretch="Uniform"
                               StretchDirection="DownOnly" />
                    </LayoutTransformControl>
                </ScrollViewer>

                <TextBlock Text="拖入图片或点击工具栏打开"
                           Foreground="#888"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsVisible="{Binding !HasImage}" />
            </Panel>
        </DockPanel>
    </Border>
</Window>
