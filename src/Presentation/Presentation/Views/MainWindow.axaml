<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ImageViewer.Presentation.ViewModels"
        xmlns:loc="using:ImageViewer.Presentation.MarkupExtensions"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="ImageViewer.Presentation.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/icon.ico"
        Title="{loc:Loc AppTitle}"
        Width="1000" Height="700"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        Background="Transparent"
        CornerRadius="16"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Window.Styles>
        <Style Selector="Border.title-bar">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
            <Setter Property="Padding" Value="16,0,16,0" />
            <Setter Property="Height" Value="40" />
        </Style>
        <Style Selector="Button.traffic-light">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>
        <Style Selector="Button.close-btn">
            <Setter Property="Background" Value="#FF5F57" />
        </Style>
        <Style Selector="Button.minimize-btn">
            <Setter Property="Background" Value="#FFBD2E" />
        </Style>
        <Style Selector="Button.maximize-btn">
            <Setter Property="Background" Value="#28C840" />
        </Style>
        <Style Selector="Button.traffic-light:pointerover /template/ContentPresenter">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Opacity" Value="0.8" />
        </Style>
        <Style Selector="Border.sidebar">
            <Setter Property="Width" Value="72" />
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}" />
            <Setter Property="Padding" Value="12,0" />
        </Style>
        <Style Selector="Button.sidebar-btn">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Margin" Value="0,4" />
        </Style>
        <Style Selector="Button.sidebar-btn /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="FontSize" Value="16" />
        </Style>
        <Style Selector="Button.sidebar-btn TextBlock">
            <Setter Property="FontSize" Value="16" />
        </Style>
        <Style Selector="Button.sidebar-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAltListLowBrush}" />
        </Style>
        <Style Selector="Button.sidebar-btn:disabled">
            <Setter Property="Opacity" Value="0.35" />
        </Style>
        <Style Selector="Button.nav-btn:disabled /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.nav-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.sidebar-separator">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
            <Setter Property="Opacity" Value="0.2" />
            <Setter Property="Margin" Value="0,8" />
        </Style>
        <Style Selector="MenuFlyoutPresenter">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="MinWidth" Value="140" />
        </Style>
        <Style Selector="MenuFlyoutPresenter MenuItem">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainViewModel>
            <x:Arguments>
                <x:Null />
                <x:Null />
                <x:Null />
            </x:Arguments>
        </vm:MainViewModel>
    </Design.DataContext>

    <Border BorderBrush="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            ClipToBounds="True"
            PointerPressed="OnWindowPointerPressed">
        <DockPanel LastChildFill="True">

            <!-- 左侧边栏（交通灯 + 工具按钮） -->
            <Border DockPanel.Dock="Left" Classes="sidebar">
                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <!-- 交通灯 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,16,0,8">
                        <Button Classes="traffic-light close-btn" Click="OnCloseClick" ToolTip.Tip="{loc:Loc Close}" />
                        <Button Classes="traffic-light minimize-btn" Click="OnMinimizeClick" ToolTip.Tip="{loc:Loc Minimize}" />
                        <Button Classes="traffic-light maximize-btn" Click="OnMaximizeClick" ToolTip.Tip="{loc:Loc Maximize}" />
                    </StackPanel>

                    <Border Grid.Row="1" Classes="sidebar-separator" HorizontalAlignment="Center" />

                    <!-- 顶部工具区 -->
                    <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,8,0,0">
                        <Button Classes="sidebar-btn" Content="📂" Click="OnOpenFolderClick" ToolTip.Tip="{loc:Loc OpenFolder}" />

                        <Border Classes="sidebar-separator" />

                        <Button Classes="sidebar-btn" Content="🔎" Command="{Binding ZoomOutCommand}"
                                ToolTip.Tip="{loc:Loc ZoomOut}" />
                        <Button Classes="sidebar-btn" Content="🔍" Command="{Binding ZoomInCommand}"
                                ToolTip.Tip="{loc:Loc ZoomIn}" />
                        <Button Classes="sidebar-btn" Content="🔄" Command="{Binding ResetTransformCommand}"
                                ToolTip.Tip="{loc:Loc Reset}" />

                        <Border Classes="sidebar-separator" />

                        <Button Classes="sidebar-btn" Content="↺" Command="{Binding RotateCounterClockwiseCommand}"
                                ToolTip.Tip="{loc:Loc RotateCounterClockwise}" />
                        <Button Classes="sidebar-btn" Content="↻" Command="{Binding RotateClockwiseCommand}"
                                ToolTip.Tip="{loc:Loc RotateClockwise}" />

                        <Border Classes="sidebar-separator" />

                        <Button x:Name="ColorPickerButton"
                                Classes="sidebar-btn" Content="🎨"
                                Command="{Binding ToggleColorPickerCommand}"
                                ToolTip.Tip="{loc:Loc ColorPicker}"
                                IsEnabled="{Binding HasImage}" />


                    </StackPanel>

                    <!-- 底部设置区 -->
                    <StackPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <Button Classes="sidebar-btn" Click="OnSettingsClick" ToolTip.Tip="{loc:Loc Settings}">
                            <PathIcon Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.22,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.22,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                                      Width="18" Height="18"
                                      Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 主体内容区（占满右侧剩余空间） -->
            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="0,16,16,0"
                    ClipToBounds="True">
                <Border.ContextFlyout>
                    <MenuFlyout>
                        <MenuItem Header="{loc:Loc ImageDetail}"
                                  Click="OnImageDetailClick"
                                  IsVisible="{Binding HasImage}" />
                        <MenuItem Header="{loc:Loc Delete}"
                                  Foreground="#E74856"
                                  Click="OnDeleteImageClick"
                                  IsVisible="{Binding HasImage}" />
                    </MenuFlyout>
                </Border.ContextFlyout>
                <Panel x:Name="ImagePanel">
                    <ScrollViewer x:Name="ImageScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  IsVisible="{Binding HasImage}">
                        <LayoutTransformControl HorizontalAlignment="Center" VerticalAlignment="Center">
                            <LayoutTransformControl.LayoutTransform>
                                <TransformGroup>
                                    <RotateTransform Angle="{Binding Rotation}" />
                                    <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}" />
                                </TransformGroup>
                            </LayoutTransformControl.LayoutTransform>
                            <Image x:Name="ImageView"
                                   Source="{Binding CurrentImage}"
                                   Stretch="Uniform"
                                   StretchDirection="DownOnly" />
                        </LayoutTransformControl>
                    </ScrollViewer>

                    <TextBlock Text="{loc:Loc OpenImagePrompt}"
                               Foreground="#888"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsVisible="{Binding !HasImage}" />

                    <Button Classes="nav-btn"
                            Command="{Binding PreviousCommand}"
                            IsEnabled="{Binding CanGoPrevious}"
                            Margin="8"
                            Width="44"
                            Height="44"
                            Padding="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Opacity="0.8"
                            IsVisible="{Binding HasImage}">
                        <TextBlock Text="◀"
                                   FontSize="20"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="6"
                                                  OffsetX="0"
                                                  OffsetY="0"
                                                  Color="#B0000000"
                                                  Opacity="0.8" />
                            </TextBlock.Effect>
                        </TextBlock>
                    </Button>

                    <Button Classes="nav-btn"
                            Command="{Binding NextCommand}"
                            IsEnabled="{Binding CanGoNext}"
                            Margin="8"
                            Width="44"
                            Height="44"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Opacity="0.8"
                            IsVisible="{Binding HasImage}">
                        <TextBlock Text="▶"
                                   FontSize="20"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="6"
                                                  OffsetX="0"
                                                  OffsetY="0"
                                                  Color="#B0000000"
                                                  Opacity="0.8" />
                            </TextBlock.Effect>
                        </TextBlock>
                    </Button>

                    <!-- 取色器颜色信息浮层 -->
                    <Border IsVisible="{Binding IsColorPickerActive}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="16"
                            Padding="12,10"
                            CornerRadius="10"
                            Background="#E0282828"
                            MaxWidth="220">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Width="36" Height="36"
                                    CornerRadius="6"
                                    Background="{Binding ColorPickerBrush}"
                                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                    BorderThickness="1" />
                            <StackPanel Spacing="2">
                                <Grid>
                                    <TextBlock Text="{Binding ColorPickerHex}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               IsVisible="{Binding !IsCopied}" />
                                    <TextBlock Text="{loc:Loc CopiedFeedback}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#4CAF50"
                                               IsVisible="{Binding IsCopied}" />
                                </Grid>
                                <TextBlock Text="{Binding ColorPickerRgb}"
                                           FontSize="11"
                                           Foreground="#A0A0A0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 取色器放大镜浮层（跟随鼠标，右上角显示） -->
                    <Border x:Name="MagnifierBorder"
                            IsVisible="{Binding MagnifierVisible}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Width="163" Height="163"
                            CornerRadius="12"
                            Background="#E0282828"
                            BorderBrush="White"
                            BorderThickness="2"
                            ClipToBounds="True">
                        <Image Source="{Binding MagnifierImage}"
                               Stretch="None"
                               Width="155" Height="155"
                               Margin="4">
                            <Image.Clip>
                                <RectangleGeometry Rect="0,0,155,155" RadiusX="8" RadiusY="8" />
                            </Image.Clip>
                        </Image>
                    </Border>
                </Panel>
            </Border>
        </DockPanel>
    </Border>
</Window>
